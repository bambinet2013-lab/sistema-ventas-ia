            if errores_recientes:
                informe["errores_criticos"].extend(errores_recientes[:5])
                informe["estadisticas"]["errores_en_logs"] = len(errores_recientes)
                
        except Exception as e:
            informe["advertencias"].append(f"Error leyendo logs: {e}")
    
