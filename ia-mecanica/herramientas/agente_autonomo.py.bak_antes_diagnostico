    def _diagnosticar_logs(self, informe):
        """Analiza logs en busca de errores"""
        try:
            log_file = "/home/junior/Escritorio/sistema-ventas-python/sistema_ventas.log"
            if not os.path.exists(log_file):
                return
            
            with open(log_file, 'r') as f:
                logs = f.readlines()[-500:]  # Últimas 500 líneas
            
            errores_recientes = []
            patrones_error = {
                "NoneType": "Acceso a objeto None - Falta validación",
                "KeyError": "Acceso a clave inexistente en diccionario",
                "IndexError": "Acceso a índice fuera de rango en lista",
                "ValueError": "Valor incorrecto para operación",
                "TypeError": "Tipo de dato incorrecto",
                "AttributeError": "Atributo no existe en objeto",
                "ConnectionError": "Error de conexión a BD",
                "Timeout": "Tiempo de espera agotado"
            }
            
            for linea in logs[-100:]:  # Últimas 100 líneas
                for patron, desc in patrones_error.items():
                    if patron in linea:
                        errores_recientes.append({
                            "tipo": patron,
                            "descripcion": desc,
                            "linea": linea.strip(),
                            "timestamp": datetime.now().isoformat()
                        })
